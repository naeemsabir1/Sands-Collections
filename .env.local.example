# Firebase Configuration for Sands Collections
# Copy this file to .env.local and fill in your values from Firebase Console

# Get these values from: https://console.firebase.google.com/project/sands-collections/settings/general
# Under "Your apps" section (add a Web app if you haven't already)

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sands-collections.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sands-collections
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sands-collections.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here
